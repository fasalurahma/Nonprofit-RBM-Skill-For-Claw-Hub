{{ header }}
<script src="catalog/view/theme/default/javascript/jquery/datetimepicker/moment/moment.min.js" type="text/javascript"></script>
<script src="catalog/view/theme/default/javascript/jquery/datetimepicker/moment/moment-with-locales.min.js" type="text/javascript"></script>
<script src="catalog/view/theme/default/javascript/jquery/datetimepicker/bootstrap-datetimepicker.min.js" type="text/javascript"></script>
<link href="catalog/view/theme/default/javascript/jquery/datetimepicker/bootstrap-datetimepicker.min.css" type="text/css" rel="stylesheet" media="screen" />
<style>
div.required .control-label:not(span):before, td.required:before {
    content: '* ';
    color: #F00;
    font-weight: bold;
}
</style>
{% if chkIsPartner %}
<div class="container">
  <ul class="breadcrumb">
    {% for breadcrumb in breadcrumbs %}
    <li><a href="{{ breadcrumb['href'] }}">{{ breadcrumb['text'] }}</a></li>
    {% endfor %}
  </ul>

  {% if error_warning %}
    <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i>{{ error_warning }}</div>
  {% endif %}
  {% if success %}
    <div class="alert alert-success"><i class="fa fa-check-circle"> </i> {{ success }}</div>
  {% endif %}
  {% if attention %}
    <div class="alert alert-info">{{ attention }}</div>
  {% endif %}

  <div class="row">{{ column_left }}
    {% if column_left and column_right %}
    {% set class = 'col-sm-6' %}
    {% elseif column_left or column_right %}
    {% set class = 'col-sm-9' %}
    {% else %}
    {% set class = 'col-sm-12' %}
    {% endif %}

  <div id="content" class="{{ class }}">{{ content_top }}
    <h1>
      {{ heading_title_hyperlocal }}
      <div class="pull-right">
        <button type="submit" form="form-timeslot" data-toggle="tooltip" title="{{ button_next }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ back }}" data-toggle="tooltip" title="{{ button_back }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
    </h1>


    <legend><i class="fa fa-list"></i> {{ text_mpshipping }}</legend>
      {% if chkIsPartner %}
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-timeslot" class="form-horizontal">
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
            <div class="col-sm-10">
              <select name="wk_hyperlocal_addon_status" id="input-status" class="form-control">
                {% if wk_hyperlocal_addon_status %}
                <option value="1" selected="selected">{{ text_enabled }}</option>
                <option value="0">{{ text_disabled }}</option>
                {% elseif wk_hyperlocal_addon_status is defined and not wk_hyperlocal_addon_status %}
                <option value="1">{{ text_enabled }}</option>
                <option value="0" selected>{{ text_disabled }}</option>
                {% else %}
                <option value="1">{{ text_enabled }}</option>
                <option value="0">{{ text_disabled }}</option>
                {% endif %}
              </select>
            </div>
          </div>

          <div class="form-group">
            <div class="table-responsive">
            <table class="table table-striped table-bordered table-hover">

              <!-- //  tpl code through php loop // -->
                    {% for key, value in weekArray %}
                    {% set textStart = value ~ "_stime" %}
                    {% set textlast = value ~ "_ltime" %}
                    {% set selectStart = 'wk_hyperlocal_addon_'~value~'_status' %}
                    {% set store_pickup = 'wk_hyperlocal_addon_'~value~'_store_pickup' %}
                    {% set startValue = 'wk_hyperlocal_addon_'~value~'_stime' %}
                    {% set lastValue = 'wk_hyperlocal_addon_'~value~'_ltime' %}
                    {% set s_error = 'wk_hyperlocal_addon_'~value~'_stime_error' %}
                    {% set l_error = 'wk_hyperlocal_addon_'~value~'_ltime_error' %}

                    <tr>
                      <td class="text-left required">
                        <b>{{ _context[textStart]}}</b>
                      </td>
                <td class="text-left">
                  <div class="input-group time required col-sm-10">
                    <input type="text" class="time form-control" size="26" name="wk_hyperlocal_addon_{{ value}}_stime" value="{% if _context[startValue] is defined %}{{ _context[startValue] }}{% endif %}" />
                  </div>
                  {%  if _context[selectStart]  is defined and  _context[selectStart]  == 'close' %}
                    <div class="alert-info">
                      <i class="fa fa-info-circle"></i>
                      {{ text_close_status}}
                    </div>
                  {% endif %}
                  {% if (_context[s_error] is defined and _context[s_error]) %}
                        <div class="text-danger">  {{ _context[s_error] }} </div>
                  {% endif %}
                </td>
                <td class="text-right" style="width:15%;">
                  <div class="text-left"><b>{{ entry_store_pick }}</b></div>
                  <select name="wk_hyperlocal_addon_{{ value }}_store_pickup" class="form-control">
                    <option {% if _context[store_pickup] == "open" %} {{"selected"}} {% endif %}  value="open">{{ text_open}} </option>
                    <option {% if _context[store_pickup] == "close" %} {{"selected"}} {% endif %}  value="close">{{ text_close}} </option>
                  </select>
                </td>
              </tr>
              <tr>
                <td class="text-left required">
                    <b>{{_context[textlast]}}</b>
                </td>
                <td class="text-left">
                  <div class="input-group time required col-sm-10">
                    <input type="text" class="time form-control" size="26" name="wk_hyperlocal_addon_{{ value}}_ltime" value="{% if _context[lastValue] is defined %}{{_context[lastValue]}}{% endif %}">
                  </div>
                  {% if _context[selectStart] is defined and _context[selectStart]  == 'close' %}
                    <div class="alert-info">
                      <i class="fa fa-info-circle"></i>
                      {{ text_close_status}}
                    </div>
                  {% endif %}
                  {% if (_context[l_error] is defined and _context[l_error]) %}
                        <div class="text-danger">  {{ _context[l_error] }} </div>
                  {% endif %}
                </td>
                <td class="text-right">
                  <div class="text-left"><b>{{ entry_day_status }}</b></div>
                  <select name="wk_hyperlocal_addon_{{ value}}_status" class="form-control">
                    <option {% if _context[selectStart] == "open" %} {{"selected"}} {% endif %}  value="open">{{ text_open}} </option>
                    <option {% if _context[selectStart] == "close" %} {{"selected"}} {% endif %}  value="close">{{ text_close}} </option>
                  </select>
                </td>
              </tr>
                {% endfor %}
            </table>
            </div>
          </div>
        </form>


        {% endif %}

{{ content_bottom }}</div>
  {% else %}
    <h2 style='color:#F93D49;'>{{ text_contact }}</h2>
  {% endif %}
{{ column_right }}</div>
</div>
<script>
$('.time').datetimepicker({
   pickDate: false,
   format: "HH:mm",
 });
</script>
{{ footer }}
