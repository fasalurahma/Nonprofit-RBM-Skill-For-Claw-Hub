{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a></div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb['href'] }}">{{ breadcrumb['text'] }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="container-fluid">
    {% if (error_warning) %}
    <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
      </div>

      <div class="panel-body">
      	<form action="{{ action }}" method="post" enctype="multipart/form-data" id="form" class="form-horizontal">
      	  <div class="form-group">
				    <label class="col-sm-2 control-label" for="seller_status">{{ text_status }}</label>
				    <div class="col-sm-10">
				      <select name="module_mpordersplit_status" id="seller_status" class="form-control">
				        <option value="1" {% if (module_mpordersplit_status) %} {{ 'selected' }}{% endif %}>  {{ text_enabled }} </option>
				        <option value="0" {% if (not module_mpordersplit_status) %} {{ 'selected' }}{% endif %}>  {{ text_disabled }} </option>
              </select>
              {% if error_module_mpordersplit_status is defined and error_module_mpordersplit_status %}
                <p class="text-danger">{{ error_module_mpordersplit_status }}</p>                
              {% endif %}
				    </div>
          </div>
          <div class="form-group">
            <label for="input-shipping-methods" class="col-sm-2 control-label"><span title="" data-toggle="tooltip" data-original-title="{{ help_shipping_method }}">{{ entry_shipping_method }} </span></label>
            <div class="col-sm-10">
              <div class="well well-sm" style="height:150px; overflow: auto;">
                {% for key,shipping_method in shipping_methods %}
                  <div>
                    <input type="checkbox" name="module_mpordersplit_allowed_shipping[]" id="module_mpordersplit_allowed_shipping_{{ key }}" value="{{ shipping_method.code }}" {% if module_mpordersplit_allowed_shipping is defined and module_mpordersplit_allowed_shipping and shipping_method.code in module_mpordersplit_allowed_shipping %} {{"checked"}} {% endif %}> {{ shipping_method.title }}
                  </div>
                {% endfor %}
              </div>
              <a class="selectAll">{{ text_selectall }}</a>&nbsp;/&nbsp;<a class="deselectAll">{{ text_deselectall }}</a>
              {% if error_module_mpordersplit_allowed_shipping is defined and error_module_mpordersplit_allowed_shipping %}
                <p class="text-danger">{{ error_module_mpordersplit_allowed_shipping }}</p>
              {% endif %}
            </div>
          </div>
          <div class="form-group">
            <label for="input-shipping-methods" class="col-sm-2 control-label"><span title="{{ help_payment_method }}" data-toggle="tooltip" data-original-title="{{ help_payment_method }}">{{ entry_payment_method }} </span></label>
            <div class="col-sm-10">
              <div class="well well-sm" style="height:150px; overflow: auto;">
                {% for key,payment_method in payment_methods %}
                  <div>
                    <input type="checkbox" name="module_mpordersplit_allowed_payment[]" id="module_mpordersplit_allowed_payment_{{ key }}" value="{{ payment_method.code }}" {% if module_mpordersplit_allowed_payment is defined and module_mpordersplit_allowed_payment and payment_method.code in module_mpordersplit_allowed_payment %} {{"checked"}} {% endif %}> {{ payment_method.title }}
                  </div>
                {% endfor %}
              </div>
              <a class="selectAll">{{ text_selectall }}</a>&nbsp;/&nbsp;<a class="deselectAll">{{ text_deselectall }}</a>
              {% if error_module_mpordersplit_allowed_payment is defined and error_module_mpordersplit_allowed_payment %}
                <p class="text-danger">{{ error_module_mpordersplit_allowed_payment }}</p>
              {% endif %}
            </div>
          </div>
	       </form>
      </div>
    </div>
  </div>
</div>
<script>
  $('.selectAll').on('click',function(){
    $(this).prev('div').find('input[type="checkbox"]').prop('checked',true);
  })
  
  $('.deselectAll').on('click',function(){
    $(this).prevAll('div').find('input[type="checkbox"]').prop('checked',false);
  })
</script>
{{ footer }}
