{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <a href="{{ addshipping }}" data-toggle="tooltip" title="{{ button_shipping }}" class="btn btn-primary"><i class="fa fa-plus"></i></a>
        <button type="button" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger" onclick="confirm('{{ text_confirm }}') ? $('#form').submit() : false;"><i class="fa fa-trash-o"></i></button>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb['href'] }}">{{ breadcrumb['text'] }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-list"></i> {{ heading_title }}</h3>
      </div>

      <div class="panel-body">
        <div class="well">
          <div class="row">

            <div class="col-sm-4">
              <div class="form-group">
                <label class="control-label" for="input-name">{{ customer_name }}</label>
                <div class='input-group'>
                  <input type="text" name="filter_name" value="{{ filter_name }}" placeholder="{{ customer_name }}" id="input-name" class="form-control" />
                  <span class="input-group-addon"><span class="fa fa-angle-double-down"></span>
                    </span>
                </div>
              </div>
              <div class="form-group">
                <label class="control-label" for="input-weight_from">{{ weight_from }}</label>
                <input type='text' name="filter_weight_from" value="{{ filter_weight_from }}" placeholder="{{ weight_from }}" id="input-weight_from" class="form-control date" />
              </div>
            </div>

            <div class="col-sm-4">
              <div class="form-group">
                <label class="control-label" for="input-range_to">{{ range_to }}</label>
                <input type="text" name="filter_range_to" value="{{ filter_range_to }}" placeholder="{{ range_to }}" id="input-range_to" class="form-control" />
              </div>
              <div class="form-group">
                <label class="control-label" for="input-range_from">{{ range_from }}</label>
                <input type="text" name="filter_range_from" value="{{ filter_range_from }}" placeholder="{{ range_from }}" id="input-range_from" class="form-control" />
              </div>
            </div>

            <div class="col-sm-4">
              <div class="form-group">
                <label class="control-label" for="input-price">{{ price }}</label>
                <input type="text" name="filter_price" value="{{ filter_price }}" placeholder="{{ price }}" id="input-price" class="form-control" />
              </div>
              <div class="form-group">
                <label class="control-label" for="input-weight_to">{{ weight_to }}</label>
                <input type="text" name="filter_weight_to" value="{{ filter_weight_to }}" placeholder="{{ weight_to }}" id="input-weight_to" class="form-control" />
              </div>
              <button type="button" onclick="filter();" class="btn btn-primary pull-right"><i class="fa fa-search"></i> {{ button_filter }}</button>
            </div>
          </div>
        </div>

        <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form">

          <div class="table-responsive">
            <table class="table table-bordered table-hover">
              <thead>
                <tr>
                <td width="1" style="text-align: center;"><input type="checkbox" onclick="$('input[name*=\'selected\']').attr('checked', this.checked);" /></td>
                  <td class="text-left">
                    {% if sort == 'name' %}
                    <a href="{{ sort_name }}" class="{{ order|lower }}">{{ customer_name }}</a>
                    {% else %}
                    <a href="{{ sort_name }}">{{ customer_name }}</a>
                    {% endif %}
                  </td>
                  <td class="text-left">
                    {% if sort == 'cs.range_from' %}
                    <a href="{{ sort_range_from }}" class="{{ order|lower }}">{{ range_from }}</a>
                    {% else %}
                    <a href="{{ sort_range_from }}">{{ range_from }}</a>
                    {% endif %}
                  </td>
                  <td class="text-left">
                    {% if sort == 'cs.range_to' %}
                    <a href="{{ sort_range_to }}" class="{{ order|lower }}">{{ range_to }}</a>
                    {% else %}
                    <a href="{{ sort_range_to }}">{{ range_to }}</a>
                    {% endif %}
                  </td>
                  <td class="text-left">
                    {% if sort == 'cs.price' %}
                    <a href="{{ sort_price }}" class="{{ order|lower }}">{{ price }}</a>
                    {% else %}
                    <a href="{{ sort_price }}">{{ price }}</a>
                    {% endif %}
                  </td>
                  <td class="text-left">
                    {% if sort == 'cs.weight_from' %}
                    <a href="{{ sort_weight_from }}" class="{{ order|lower }}">{{ weight_from }}</a>
                    {% else %}
                    <a href="{{ sort_weight_from }}">{{ weight_from }}</a>
                    {% endif %}
                  </td>
                  <td class="text-left">
                    {% if sort == 'cs.weight_to' %}
                    <a href="{{ sort_weight_to }}" class="{{ order|lower }}">{{ weight_to }}</a>
                    {% else %}
                    <a href="{{ sort_weight_to }}">{{ weight_to }}</a>
                    {% endif %}
                  </td>
                </tr>
              </thead>

              <tbody>
                {% if result_shipping is defined and result_shipping %}
                  {% for result_shippings in result_shipping %}
                  <tr>
                    <td style="text-align: center;">{% if result_shippings['selected'] is defined and  result_shippings['selected'] %}
                      <input type="checkbox" name="selected[]" value="{{ result_shippings['id'] }}" checked="checked" />
                      {% else %}
                      <input type="checkbox" name="selected[]" value="{{ result_shippings['id'] }}" />
                      {% endif %}
                    </td>
                      <td class="text-left" >{{ result_shippings['name'] }}</td>
                      <td class="text-left" >{{ result_shippings['range_from'] }}</td>
                      <td class="text-left">{{ result_shippings['range_to'] }}</td>
                      <td class="text-left">{{ result_shippings['price'] }}</td>
                      <td class="text-left">{{ result_shippings['weight_from'] }}</td>
                      <td class="text-left">{{ result_shippings['weight_to'] }}</td>
                  </tr>
                {% endfor %}
                {% else %}
                <tr>
                  <td class="text-center" colspan="12">{{ "no records founds" }}</td>
                </tr>
                {% endif %}
              </tbody>
            </table>
          </div>
        </form>
        <div class="row">
          <div class="col-sm-6 text-left">{{ pagination }}</div>
          <div class="col-sm-6 text-right">{{ results }}</div>
        </div>

      </div>
    </div>
  </div>
</div>

<script type="text/javascript"><!--

$('#form input').keydown(function(e) {
  if (e.keyCode == 13) {
    filter();
  }
});

function filter() {

  url = 'index.php?route=hyperlocal/shippinglist&user_token={{ user_token }}';

  var filter_name = $('input[name=\'filter_name\']').val();

  if (filter_name) {
    url += '&filter_name=' + encodeURIComponent(filter_name);
  }

  var filter_price = $('input[name=\'filter_price\']').val();

  if (filter_price) {
    url += '&filter_price=' + encodeURIComponent(filter_price);
  }

  var filter_range_to = $('input[name=\'filter_range_to\']').val();

  if (filter_range_to) {
    url += '&filter_range_to=' + encodeURIComponent(filter_range_to);
  }

  var filter_range_from = $('input[name=\'filter_range_from\']').val();

  if (filter_range_from) {
    url += '&filter_range_from=' + encodeURIComponent(filter_range_from);
  }

  var filter_weight_to = $('input[name=\'filter_weight_to\']').val();

  if (filter_weight_to) {
    url += '&filter_weight_to=' + encodeURIComponent(filter_weight_to);
  }

  var filter_weight_from = $('input[name=\'filter_weight_from\']').val();

  if (filter_weight_from) {
    url += '&filter_weight_from=' + encodeURIComponent(filter_weight_from);
  }

  location = url;
}

$('input[name=\'filter_name\']').autocomplete({
  delay: 0,
  source: function(request, response) {

    $.ajax({
      url: 'index.php?route=customerpartner/partner/autocomplete&user_token={{ user_token }}&filter_name=' +  encodeURIComponent(request),
      dataType: 'json',
      success: function(json) {
        response($.map(json, function(item) {
          return {
            label: item.name,
            value: item.id
          }
        }));
      }
    });
  },
  select: function(item) {
    $('input[name=\'filter_name\']').val(item.label);

    return false;
  },
  focus: function(item) {
      return false;
  }
});
//--></script>
{{ footer }}
